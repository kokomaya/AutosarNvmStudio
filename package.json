          "group": "navigation@2"
        },
        {
          "command": "nvmStudio.nvm.blocks.configureColumns",
          "when": "view == hexEditor.nvmBlocks",
          "group": "navigation@3"
        },
        {
          "command": "nvmStudio.nvm.blocks.refresh",
          "when": "view == hexEditor.nvmBlocks",
          "group": "navigation@4"
        },
        {
          "command": "nvmStudio.nvm.blocks.clearFilter",
          "when": "view == hexEditor.nvmBlocks",
          "group": "1_filter@1"
        },
        {
          "command": "nvmStudio.nvm.openReportPreview",
          "when": "view == hexEditor.nvmStudio",
          "group": "navigation@1"
        },
        {
          "command": "nvmStudio.nvm.openChat",
          "when": "view == hexEditor.nvmStudio",
          "group": "navigation@2"
        },
        {
          "command": "nvmStudio.nvm.reloadLayout",
          "when": "view == hexEditor.nvmStudio",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "nvmStudio.nvm.customViews.addBlock",
          "when": "view == hexEditor.nvmBlocks && viewItem == nvmBlock",
          "group": "inline@1"
        },
        {
          "command": "nvmStudio.nvm.customViews.addBlock",
          "when": "view == hexEditor.nvmBlocks && viewItem == nvmBlock",
          "group": "1_view@1"
        },
        {
          "command": "nvmStudio.nvm.openNoteNode",
          "when": "view == hexEditor.nvmStudio && viewItem == note",
          "group": "inline@1"
        },
        {
          "command": "nvmStudio.nvm.renameBookmark",
          "when": "view == hexEditor.nvmStudio && viewItem == bookmark",
          "group": "inline@1"
        },
        {
          "command": "nvmStudio.nvm.deleteAnnotation",
          "when": "view == hexEditor.nvmStudio && viewItem =~ /bookmark|note|tagAssignment/",
          "group": "inline@2"
        },
        {
          "command": "nvmStudio.nvm.openNoteNode",
          "when": "view == hexEditor.nvmStudio && viewItem == note"
        }
      ],
      "editor/title": [
        {
          "command": "nvmStudio.openFile",
          "group": "navigation@1",
          "when": "activeEditor && config.nvmstudio.showOpenFileButton"
        },
        {
          "command": "nvmStudio.nvm.openReportPreview",
          "group": "navigation@2",
          "when": "activeCustomEditorId == hexEditor.hexedit"
        },
        {
          "command": "nvmStudio.nvm.openChat",
          "group": "navigation@3",
          "when": "activeCustomEditorId == hexEditor.hexedit"
        }
      ],
      "webview/context": [
        {
          "command": "nvmStudio.nvm.addBookmarkHere",
          "group": "nvm@1",
          "when": "hexEditor:isActive"
        },
        {
          "command": "nvmStudio.nvm.addNoteHere",
          "group": "nvm@2",
          "when": "hexEditor:isActive"
        },
        {
          "command": "nvmStudio.nvm.tagSelectionHere",
          "group": "nvm@3",
          "when": "hexEditor:isActive"
        },
        {
          "command": "nvmStudio.nvm.removeTagHere",
          "group": "nvm@4",
          "when": "hexEditor:isActive"
        },
        {
          "command": "nvmStudio.nvm.openReportPreview",
          "group": "nvm@5",
          "when": "hexEditor:isActive"
        },
        {
          "command": "nvmStudio.copyOffsetAsDec",
          "group": "9_cutcopypaste",
          "when": "hexEditor:isActive"
        },
        {
          "command": "nvmStudio.copyOffsetAsHex",
          "group": "9_cutcopypaste",
          "when": "hexEditor:isActive"
        },
        {
          "when": "webviewId == 'hexEditor.hexedit'",
          "command": "nvmStudio.copyAs",
          "group": "9_cutcopypaste"
        }
      ],
      "explorer/context": [
        {
          "command": "nvmStudio.compareSelected",
          "group": "3_compare@30",
          "when": "listDoubleSelection"
        }
      ]
    },
    "keybindings": [
      {
        "command": "nvmStudio.goToOffset",
        "key": "ctrl+g",
        "when": "activeCustomEditorId == hexEditor.hexedit"
      },
      {
        "command": "nvmStudio.copyAs",
        "key": "alt+ctrl+c",
        "when": "activeCustomEditorId == hexEditor.hexedit"
      },
      {
        "command": "nvmStudio.switchEditMode",
        "key": "Insert",
        "when": "hexEditor:isActive"
      },
      {
        "command": "nvmStudio.nvm.addBookmarkHere",
        "key": "ctrl+alt+b",
        "when": "activeCustomEditorId == hexEditor.hexedit"
      },
      {
        "command": "nvmStudio.nvm.addNoteHere",
        "key": "ctrl+alt+n",
        "when": "activeCustomEditorId == hexEditor.hexedit"
      },
      {
        "command": "nvmStudio.nvm.tagSelectionHere",
        "key": "ctrl+alt+t",
        "when": "activeCustomEditorId == hexEditor.hexedit"
      }
    ]
  },
  "scripts": {
    "compile:core": "tsc --noEmit && node .esbuild.config.js",
    "server:build": "node server/build-server.mjs",
    "compile": "npm run compile:core && npm run server:build",
    "lint": "eslint src",
    "fmt": "prettier --write \"{src,media,shared}/**/*.{ts,tsx}\" && npm run lint -- --fix",
    "watch": "node .esbuild.config.js --watch",
    "test": "tsc --noEmit && node ./src/test/runTest.js",
    "nvmcli:build": "esbuild tools/nvmcli.ts --bundle --platform=node --outfile=dist/nvmcli.js",
    "vscode:prepublish": "npm run compile",
    "package:vsix": "vsce package --no-dependencies -o dist/nvm-studio.vsix"
  },
  "devDependencies": {
    "@types/chai": "^5",
    "@types/diff": "^5.2.1",
    "@types/mocha": "^10",
    "@types/node": "^22",
    "@types/react": "^17.0.38",
    "@types/react-dom": "^17.0.11",
    "@types/vscode": "^1.89.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "chai": "^6",
    "esbuild": "^0.25",
    "esbuild-css-modules-plugin": "^3.1.0",
    "esbuild-plugin-svgr": "^3",
    "eslint": "^9",
    "globals": "^16",
    "mocha": "^11.1.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.6",
    "@vscode/codicons": "0.0.27",
    "@vscode/extension-telemetry": "^1.5.1",
    "cockatiel": "^3.1.2",
    "diff": "^8.0.3",
    "js-base64": "^3.7.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-popper": "^2.3.0",
    "recoil": "^0.7.7",
    "vscode-webview-tools": "^0.1.1"
  },
  "prettier": {
    "printWidth": 100,
