{
  "name": "nvm-studio",
  "displayName": "%name%",
  "description": "%description%",
  "version": "1.0.0",
  "aiKey": "0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255",
  "publisher": "kokomaya",
  "license": "MIT",
  "engines": {
    "vscode": "^1.89.0-insider"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "browser": "./dist/web/extension.js",
  "l10n": "./l10n",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "contributes": {
    "configuration": [
      {
        "title": "%name%",
        "properties": {
          "nvmstudio.inspectorType": {
            "type": "string",
            "enum": [
              "aside",
              "hover",
              "sidebar"
            ],
            "default": "aside",
            "description": "%hexeditor.inspectorType%"
          },
          "nvmstudio.maxFileSize": {
            "type": "number",
            "minimum": 0,
            "default": 10,
            "description": "%hexeditor.maxFileSize%"
          },
          "nvmstudio.dataInspector.autoReveal": {
            "type": "boolean",
            "default": true,
            "description": "%hexeditor.dataInspector.autoReveal%"
          },
          "nvmstudio.defaultEndianness": {
            "type": "string",
            "default": "little",
            "enum": [
              "little",
              "big"
            ],
            "description": "%hexeditor.defaultEndianness%"
          },
          "nvmstudio.columnWidth": {
            "type": "integer",
            "default": 16,
            "minimum": 1,
            "maximum": 512,
            "description": "%hexeditor.columnWidth%"
          },
          "nvmstudio.copyType": {
            "type": "string",
            "enum": [
              "Hex Octets",
              "Hex",
              "Literal",
              "UTF-8",
              "C",
              "Go",
              "Java",
              "JSON",
              "Base64"
            ],
            "default": "Hex Octets",
            "description": "%hexeditor.copyType%"
          },
          "nvmstudio.showDecodedText": {
            "type": "boolean",
            "default": true,
            "description": "%hexeditor.showDecodedText%"
          },
          "nvmstudio.showOpenFileButton": {
            "type": "boolean",
            "default": false,
            "description": "%hexeditor.showOpenFileButton%"
          },
          "nvmstudio.autoLoadArxml": {
            "type": "boolean",
            "default": true,
            "description": "Automatically load an ARXML file from the same directory as the opened binary (if present)."
          },
          "nvmstudio.nvm.allowExternalEngines": {
            "type": "boolean",
            "default": true,
            "description": "Master switch for NVM layout engines. When a layout descriptor (`*.nvmlayout.json`) declares an `engineScript`/`engine`, it is executed to parse the dump — but only in the desktop extension host, in a trusted workspace, and after a one-time per-file confirmation. Set to `false` to disable engines entirely for locked-down environments."
          },
          "nvmstudio.nvm.annotationStorage": {
            "type": "string",
            "enum": [
              "sidecar",
              "workspaceState"
            ],
            "enumDescriptions": [
              "Store bookmarks/tags/notes in a portable sidecar file next to the dump (<dump>.nvmstudio.json + a <dump>.nvmstudio/ folder for note markdown/images).",
              "Store annotations in VS Code workspace state (not shareable, no files created)."
            ],
            "default": "sidecar",
            "description": "Where NVM bookmarks, tags and notes are persisted."
          },
          "nvmstudio.nvm.workspaceRoots": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "scope": "resource",
            "markdownDescription": "Root folders searched **recursively** to auto-find dependency files a layout descriptor declares (e.g. `Fee_Lcfg.c`, `Dem_Lcfg.h`, `*.arxml`) when they aren't next to the dump or in `./conf`/`../conf`. This is **not** the dump folder and **not** the auto-discovery `./conf`/`../conf` (those are always searched). Supports `${workspaceFolder}` and `${workspaceFolder:Name}`. When several files share a name you'll be asked which to use, and the choice is remembered (see `#nvmstudio.nvm.fileChoices#`). The plugin never downloads files — fetch remote ones into a root yourself."
          },
          "nvmstudio.nvm.layoutRoots": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "scope": "resource",
            "markdownDescription": "Global folders scanned for layout **descriptors** (`*.nvmlayout.json`) so they don't have to sit next to each dump. Each listed folder **and its `conf/` subfolder** are scanned directly (works for absolute paths outside the workspace, e.g. a shared user folder). This is separate from `#nvmstudio.nvm.workspaceRoots#`, which finds the descriptor's declared **source** files. Supports `${workspaceFolder}` and `${workspaceFolder:Name}`."
          },
          "nvmstudio.nvm.fileChoices": {
            "type": "object",
            "default": {},
            "scope": "resource",
            "markdownDescription": "Remembered dependency-file disambiguation choices (base file name → `{ relPath, root }`), written automatically when you pick among duplicates. Portable/shareable: paths are relative to a workspace root so they re-resolve on another machine. Use the command **NVM: Reselect Dependency File** to change a choice. A machine-local absolute-path cache is kept separately in workspace state."
          }
        }
      }
    ],
    "configurationDefaults": {
      "workbench.editorAssociations": {
        "{hexdiff}:/**/*.*": "hexEditor.hexedit",
        "*.mot": "hexEditor.hexedit",
        "*.srec": "hexEditor.hexedit",
        "*.s19": "hexEditor.hexedit",
        "*.s28": "hexEditor.hexedit",
        "*.s37": "hexEditor.hexedit",
        "*.s1": "hexEditor.hexedit",
        "*.s2": "hexEditor.hexedit",
        "*.s3": "hexEditor.hexedit",
        "*.hex": "hexEditor.hexedit",
        "*.ihex": "hexEditor.hexedit",
        "*.ihx": "hexEditor.hexedit"
      }
    },
    "customEditors": [
      {
        "viewType": "hexEditor.hexedit",
        "displayName": "%name%",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ],
        "priority": "option"
      }
    ],
