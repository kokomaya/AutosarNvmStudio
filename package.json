{
  "name": "hexeditor",
  "displayName": "%name%",
  "description": "%description%",
  "version": "1.11.1",
  "aiKey": "0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255",
  "publisher": "ms-vscode",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/vscode-hexeditor"
  },
  "bugs": {
    "url": "https://github.com/microsoft/vscode-hexeditor/issues"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.89.0-insider"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
	"activationEvents": [],
  "main": "./dist/extension.js",
  "browser": "./dist/web/extension.js",
  "l10n": "./l10n",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "contributes": {
    "configuration": [
      {
        "title": "%name%",
        "properties": {
          "hexeditor.inspectorType": {
            "type": "string",
            "enum": [
              "aside",
              "hover",
              "sidebar"
            ],
            "default": "aside",
            "description": "%hexeditor.inspectorType%"
          },
          "hexeditor.maxFileSize": {
            "type": "number",
            "minimum": 0,
            "default": 10,
            "description": "%hexeditor.maxFileSize%"
          },
          "hexeditor.dataInspector.autoReveal": {
            "type": "boolean",
            "default": true,
            "description": "%hexeditor.dataInspector.autoReveal%"
          },
          "hexeditor.defaultEndianness": {
            "type": "string",
            "default": "little",
            "enum": [
              "little",
              "big"
            ],
            "description": "%hexeditor.defaultEndianness%"
          },
          "hexeditor.columnWidth": {
            "type": "integer",
            "default": 16,
            "minimum": 1,
            "maximum": 512,
            "description": "%hexeditor.columnWidth%"
          },
          "hexeditor.copyType": {
            "type": "string",
            "enum": [
              "Hex Octets",
              "Hex",
              "Literal",
              "UTF-8",
              "C",
              "Go",
              "Java",
              "JSON",
              "Base64"
            ],
            "default": "Hex Octets",
            "description": "%hexeditor.copyType%"
          },
          "hexeditor.showDecodedText": {
            "type": "boolean",
            "default": true,
            "description": "%hexeditor.showDecodedText%"
          },
          "hexeditor.showOpenFileButton": {
            "type": "boolean",
            "default": false,
            "description": "%hexeditor.showOpenFileButton%"
          }
          ,
          "hexeditor.autoLoadArxml": {
            "type": "boolean",
            "default": true,
            "description": "Automatically load an ARXML file from the same directory as the opened binary (if present)."
          },
          "hexeditor.nvm.allowExternalEngines": {
            "type": "boolean",
            "default": true,
            "description": "Master switch for NVM layout engines. When a layout descriptor (`*.nvmlayout.json`) declares an `engineScript`/`engine`, it is executed to parse the dump — but only in the desktop extension host, in a trusted workspace, and after a one-time per-file confirmation. Set to `false` to disable engines entirely for locked-down environments."
          },
          "hexeditor.nvm.annotationStorage": {
            "type": "string",
            "enum": [
              "sidecar",
              "workspaceState"
            ],
            "enumDescriptions": [
              "Store bookmarks/tags/notes in a portable sidecar file next to the dump (<dump>.nvmstudio.json + a <dump>.nvmstudio/ folder for note markdown/images).",
              "Store annotations in VS Code workspace state (not shareable, no files created)."
            ],
            "default": "sidecar",
            "description": "Where NVM bookmarks, tags and notes are persisted."
          }
        }
      }
    ],
    "configurationDefaults": {
      "workbench.editorAssociations": {
        "{hexdiff}:/**/*.*": "hexEditor.hexedit"
      }
    },
    "customEditors": [
      {
        "viewType": "hexEditor.hexedit",
        "displayName": "%name%",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "hexEditor.openFile",
        "category": "%name%",
        "title": "%hexEditor.openFile%",
        "icon": "$(file-binary)"
      },
      {
        "command": "hexEditor.goToOffset",
        "category": "%name%",
        "title": "%hexEditor.goToOffset%"
      },
      {
        "command": "hexEditor.selectBetweenOffsets",
        "category": "%name%",
        "title": "%hexEditor.selectBetweenOffsets%"
      },
      {
        "command": "hexEditor.copyAs",
        "category": "%name%",
        "title": "%hexEditor.copyAs%"
      },
      {
        "command": "hexEditor.switchEditMode",
        "category": "%name%",
        "title": "%hexEditor.switchEditMode%"
      },
      {
        "command": "hexEditor.copyOffsetAsHex",
        "category": "%name%",
        "title": "%hexEditor.copyOffsetAsHex%"
      },
      {
        "command": "hexEditor.copyOffsetAsDec",
        "category": "%name%",
        "title": "%hexEditor.copyOffsetAsDec%"
      },
      {
        "command": "hexEditor.loadNvmArxml",
        "category": "%name%",
        "title": "Load NVM ARXML"
      },
      {
        "command": "hexEditor.nvm.installEngine",
        "category": "NVM",
        "title": "Install Engine…"
      },
      {
        "command": "hexEditor.nvm.installEngineFromUrl",
        "category": "NVM",
        "title": "Install Engine from URL…"
      },
      {
        "command": "hexEditor.nvm.manageEngines",
        "category": "NVM",
        "title": "Manage Engines…"
      },
      {
        "command": "hexEditor.nvm.jumpTo",
        "category": "NVM",
        "title": "Jump to Annotation"
      },
      {
        "command": "hexEditor.nvm.blocks.arrange.flat",
        "category": "NVM",
        "title": "Flat (by address)"
      },
      {
        "command": "hexEditor.nvm.blocks.arrange.sector",
        "category": "NVM",
        "title": "Group by sector"
      },
      {
        "command": "hexEditor.nvm.blocks.arrange.write",
        "category": "NVM",
        "title": "Order by write time"
      },
      {
        "command": "hexEditor.nvm.blocks.arrange.identity",
        "category": "NVM",
        "title": "Group by block id"
      },
      {
        "command": "hexEditor.nvm.blocks.filter",
        "category": "NVM",
        "title": "Filter Blocks…",
        "icon": "$(search)"
      },
      {
        "command": "hexEditor.nvm.blocks.clearFilter",
        "category": "NVM",
        "title": "Clear Block Filter",
        "icon": "$(clear-all)"
      },
      {
        "command": "hexEditor.nvm.blocks.configureColumns",
        "category": "NVM",
        "title": "Choose Block Columns…",
        "icon": "$(settings-gear)"
      },
      {
        "command": "hexEditor.nvm.blocks.refresh",
        "category": "NVM",
        "title": "Refresh Blocks",
        "icon": "$(refresh)"
      },
      {
        "command": "hexEditor.nvm.customViews.addBlock",
        "category": "NVM",
        "title": "Add Block to Custom View",
        "icon": "$(add)"
      },
      {
        "command": "hexEditor.nvm.openNoteNode",
        "category": "NVM",
        "title": "Open Note",
        "icon": "$(go-to-file)"
      },
      {
        "command": "hexEditor.nvm.deleteAnnotation",
        "category": "NVM",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "hexEditor.nvm.exportReport",
        "category": "NVM",
        "title": "Export Report…"
      },
      {
        "command": "hexEditor.nvm.openReportPreview",
        "category": "NVM",
        "title": "Open Report Preview",
        "icon": "$(preview)"
      },
      {
        "command": "hexEditor.nvm.openChat",
        "category": "NVM",
        "title": "Ask NVM AI",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "hexEditor.nvm.addBookmarkHere",
        "category": "NVM",
        "title": "Add Bookmark Here",
        "icon": "$(bookmark)"
      },
      {
        "command": "hexEditor.nvm.addNoteHere",
        "category": "NVM",
        "title": "Add Note Here",
        "icon": "$(note)"
      },
      {
        "command": "hexEditor.nvm.tagSelectionHere",
        "category": "NVM",
        "title": "Tag Selection…",
        "icon": "$(tag)"
      },
      {
        "command": "hexEditor.nvm.removeTagHere",
        "category": "NVM",
        "title": "Remove Tag Here"
      },
      {
        "command": "hexEditor.compareSelected",
        "category": "%name%",
        "title": "%hexEditor.compareSelected%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hexExplorer",
          "title": "%name%",
          "icon": "panel-icon.svg",
          "when": "hexEditor:showSidebarInspector"
        },
        {
          "id": "nvmStudio",
          "title": "NVM Studio",
          "icon": "panel-icon.svg"
        }
      ]
    },
    "views": {
      "hexExplorer": [
        {
          "type": "webview",
          "id": "hexEditor.dataInspectorView",
          "name": "%dataInspectorView%",
          "when": "hexEditor:showSidebarInspector"
        }
      ],
      "nvmStudio": [
        {
          "id": "hexEditor.nvmBlocks",
          "name": "Blocks"
        },
        {
          "type": "webview",
          "id": "hexEditor.nvmBlocksTable",
          "name": "Blocks Table"
        },
        {
          "type": "webview",
          "id": "hexEditor.nvmCustomViews",
          "name": "Custom Views"
        },
        {
          "id": "hexEditor.nvmStudio",
          "name": "Annotations"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "hexEditor.nvm",
        "name": "nvm",
        "fullName": "NVM Studio",
        "description": "Ask about the active AUTOSAR NVM dump (blocks, tags, notes, risks).",
        "isSticky": true
      }
    ],
    "languageModelTools": [
      {
        "name": "nvm_listBlocks",
        "displayName": "NVM: list blocks",
        "modelDescription": "List the parsed NVM blocks of the active hex-editor dump (name, offset, length, field count).",
        "toolReferenceName": "nvmListBlocks",
        "canBeReferencedInPrompt": true,
        "icon": "$(list-flat)",
        "tags": ["nvm", "hexeditor"]
      },
      {
        "name": "nvm_analyzeBlock",
        "displayName": "NVM: analyze block",
        "modelDescription": "Return the fields and metadata of a single NVM block in the active dump, matched by name.",
        "toolReferenceName": "nvmAnalyzeBlock",
        "canBeReferencedInPrompt": true,
        "icon": "$(search)",
        "tags": ["nvm", "hexeditor"],
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "The block name (or a substring) to analyze."
            }
          },
          "required": ["name"]
        }
      },
      {
        "name": "nvm_listAnnotations",
        "displayName": "NVM: list annotations",
        "modelDescription": "List the bookmarks, tags and notes the user created on the active NVM dump.",
        "toolReferenceName": "nvmListAnnotations",
        "canBeReferencedInPrompt": true,
        "icon": "$(bookmark)",
        "tags": ["nvm", "hexeditor"]
      },
      {
        "name": "nvm_exportReport",
        "displayName": "NVM: export report",
        "modelDescription": "Produce a Markdown analysis report for the active NVM dump combining parsed blocks with the user's bookmarks, tags and notes.",
        "toolReferenceName": "nvmExportReport",
        "canBeReferencedInPrompt": true,
        "icon": "$(file)",
        "tags": ["nvm", "hexeditor"]
      },
      {
        "name": "nvm_riskDetection",
        "displayName": "NVM: risk detection",
        "modelDescription": "Run heuristic checks over the active NVM dump's parsed blocks (unresolved names, zero-length blocks, overlaps) and report potential risks.",
        "toolReferenceName": "nvmRiskDetection",
        "canBeReferencedInPrompt": true,
        "icon": "$(warning)",
        "tags": ["nvm", "hexeditor"]
      }
    ],
    "submenus": [
      {
        "id": "hexEditor.nvm.blocks.arrangeMenu",
        "label": "Arrange Blocks",
        "icon": "$(list-tree)"
      }
    ],
    "menus": {
      "hexEditor.nvm.blocks.arrangeMenu": [
        {
          "command": "hexEditor.nvm.blocks.arrange.flat",
          "group": "arrange@1"
        },
        {
          "command": "hexEditor.nvm.blocks.arrange.sector",
          "group": "arrange@2"
        },
        {
          "command": "hexEditor.nvm.blocks.arrange.write",
          "group": "arrange@3"
        },
        {
          "command": "hexEditor.nvm.blocks.arrange.identity",
          "group": "arrange@4"
        }
      ],
      "commandPalette": [
        {
          "command": "hexEditor.goToOffset",
          "when": "hexEditor:isActive"
        },
        {
          "command": "hexEditor.switchEditMode",
          "when": "hexEditor:isActive"
        },
        {
          "command": "hexEditor.compareSelected",
          "when": "false"
        },
        {
          "command": "hexEditor.nvm.jumpTo",
          "when": "false"
        },
        {
          "command": "hexEditor.nvm.openNoteNode",
          "when": "false"
        },
        {
          "command": "hexEditor.nvm.deleteAnnotation",
          "when": "false"
        },
        {
          "command": "hexEditor.nvm.addBookmarkHere",
          "when": "hexEditor:isActive"
        },
        {
          "command": "hexEditor.nvm.addNoteHere",
          "when": "hexEditor:isActive"
        },
        {
          "command": "hexEditor.nvm.tagSelectionHere",
          "when": "hexEditor:isActive"
        },
        {
          "command": "hexEditor.nvm.removeTagHere",
          "when": "hexEditor:isActive"
        }
      ],
      "view/title": [
        {
          "submenu": "hexEditor.nvm.blocks.arrangeMenu",
          "when": "view == hexEditor.nvmBlocks",
          "group": "navigation@1"
        },
        {
          "command": "hexEditor.nvm.blocks.filter",
          "when": "view == hexEditor.nvmBlocks",
          "group": "navigation@2"
        },
        {
          "command": "hexEditor.nvm.blocks.configureColumns",
          "when": "view == hexEditor.nvmBlocks",
          "group": "navigation@3"
        },
        {
          "command": "hexEditor.nvm.blocks.refresh",
          "when": "view == hexEditor.nvmBlocks",
          "group": "navigation@4"
        },
        {
          "command": "hexEditor.nvm.blocks.clearFilter",
          "when": "view == hexEditor.nvmBlocks",
          "group": "1_filter@1"
        },
        {
          "command": "hexEditor.nvm.openReportPreview",
          "when": "view == hexEditor.nvmStudio",
          "group": "navigation@1"
        },
        {
          "command": "hexEditor.nvm.openChat",
          "when": "view == hexEditor.nvmStudio",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "hexEditor.nvm.customViews.addBlock",
          "when": "view == hexEditor.nvmBlocks && viewItem == nvmBlock",
          "group": "inline@1"
        },
        {
          "command": "hexEditor.nvm.customViews.addBlock",
          "when": "view == hexEditor.nvmBlocks && viewItem == nvmBlock",
          "group": "1_view@1"
        },
        {
          "command": "hexEditor.nvm.openNoteNode",
          "when": "view == hexEditor.nvmStudio && viewItem == note",
          "group": "inline@1"
        },
        {
          "command": "hexEditor.nvm.deleteAnnotation",
          "when": "view == hexEditor.nvmStudio && viewItem =~ /bookmark|note|tagAssignment/",
          "group": "inline@2"
        },
        {
          "command": "hexEditor.nvm.openNoteNode",
          "when": "view == hexEditor.nvmStudio && viewItem == note"
        }
      ],
      "editor/title": [
        {
          "command": "hexEditor.openFile",
          "group": "navigation@1",
          "when": "activeEditor && config.hexeditor.showOpenFileButton"
        },
        {
          "command": "hexEditor.nvm.openReportPreview",
          "group": "navigation@2",
          "when": "activeCustomEditorId == hexEditor.hexedit"
        },
        {
          "command": "hexEditor.nvm.openChat",
          "group": "navigation@3",
          "when": "activeCustomEditorId == hexEditor.hexedit"
        }
      ],
      "webview/context": [
        {
          "command": "hexEditor.nvm.addBookmarkHere",
          "group": "nvm@1",
          "when": "hexEditor:isActive"
        },
        {
          "command": "hexEditor.nvm.addNoteHere",
          "group": "nvm@2",
          "when": "hexEditor:isActive"
        },
        {
          "command": "hexEditor.nvm.tagSelectionHere",
          "group": "nvm@3",
          "when": "hexEditor:isActive"
        },
        {
          "command": "hexEditor.nvm.removeTagHere",
          "group": "nvm@4",
          "when": "hexEditor:isActive"
        },
        {
          "command": "hexEditor.nvm.openReportPreview",
          "group": "nvm@5",
          "when": "hexEditor:isActive"
        },
        {
          "command": "hexEditor.copyOffsetAsDec",
          "group": "9_cutcopypaste",
          "when": "hexEditor:isActive"
        },
        {
          "command": "hexEditor.copyOffsetAsHex",
          "group": "9_cutcopypaste",
          "when": "hexEditor:isActive"
        },
        {
          "when": "webviewId == 'hexEditor.hexedit'",
          "command": "hexEditor.copyAs",
          "group": "9_cutcopypaste"
        }
      ],
      "explorer/context": [
        {
          "command": "hexEditor.compareSelected",
          "group": "3_compare@30",
          "when": "listDoubleSelection"
        }
      ]
    },
    "keybindings": [
      {
        "command": "hexEditor.goToOffset",
        "key": "ctrl+g",
        "when": "activeCustomEditorId == hexEditor.hexedit"
      },
      {
        "command": "hexEditor.copyAs",
        "key": "alt+ctrl+c",
        "when": "activeCustomEditorId == hexEditor.hexedit"
      },
      {
        "command": "hexEditor.switchEditMode",
        "key": "Insert",
        "when": "hexEditor:isActive"      },
      {
        "command": "hexEditor.nvm.addBookmarkHere",
        "key": "ctrl+alt+b",
        "when": "activeCustomEditorId == hexEditor.hexedit"
      },
      {
        "command": "hexEditor.nvm.addNoteHere",
        "key": "ctrl+alt+n",
        "when": "activeCustomEditorId == hexEditor.hexedit"
      },
      {
        "command": "hexEditor.nvm.tagSelectionHere",
        "key": "ctrl+alt+t",
        "when": "activeCustomEditorId == hexEditor.hexedit"      }
    ]
  },
  "scripts": {
    "compile": "tsc --noEmit && node .esbuild.config.js",
    "lint": "eslint src",
    "fmt": "prettier --write \"{src,media,shared}/**/*.{ts,tsx}\" && npm run lint -- --fix",
    "watch": "node .esbuild.config.js --watch",
    "test": "tsc --noEmit && node ./src/test/runTest.js",
    "nvmcli:build": "esbuild tools/nvmcli.ts --bundle --platform=node --outfile=dist/nvmcli.js"
  },
  "devDependencies": {
    "@types/chai": "^5",
    "@types/diff": "^5.2.1",
    "@types/mocha": "^10",
    "@types/node": "^22",
    "@types/react": "^17.0.38",
    "@types/react-dom": "^17.0.11",
    "@types/vscode": "^1.89.0",
    "@vscode/test-electron": "^2.5.2",
    "chai": "^6",
    "esbuild": "^0.25",
    "esbuild-css-modules-plugin": "^3.1.0",
    "esbuild-plugin-svgr": "^3",
    "eslint": "^9",
    "globals": "^16",
    "mocha": "^11.1.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.6",
    "@vscode/codicons": "0.0.27",
    "@vscode/extension-telemetry": "^1.5.1",
    "cockatiel": "^3.1.2",
    "diff": "^8.0.3",
    "js-base64": "^3.7.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-popper": "^2.3.0",
    "recoil": "^0.7.7",
    "vscode-webview-tools": "^0.1.1"
  },
  "prettier": {
    "printWidth": 100,
    "tabWidth": 2,
    "arrowParens": "avoid"
  }
}
